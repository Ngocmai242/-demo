{
    "name": "aurafit-project",
    "version": "1.0.0",
    "description": "AI Virtual Fitting & Style Recommendation Platform",
    "scripts": {
        "start": "concurrently \"npm run backend\" \"npm run open\"",
        "backend": "python backend/server_dev.py",
        "frontend": "http-server frontend -a 127.0.0.1 -p 5501 -c-1 --cors -o admin_login.html",
        "open": "node -e \"setTimeout(() => { require('child_process').exec('start http://127.0.0.1:8080/admin_login.html'); }, 12000)\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "http-server": "^14.1.1"
    }
}
